# =========================
# Confirmed: Work x Genre (2-row policy)
# =========================

class VideoGenre(models.Model):
    """
    2行運用：
    - 大ジャンル行: medium_genre=NULL
    - 中ジャンル行: medium_genre!=NULL (majorはmediumから自動整合)
    """
    video = models.ForeignKey(
        Work,
        on_delete=models.CASCADE,
        related_name="genre_relations",
    )

    major_genre = models.ForeignKey(
        MajorGenre,
        on_delete=models.CASCADE,
        related_name="video_relations",
    )

    medium_genre = models.ForeignKey(
        MediumGenre,
        on_delete=models.CASCADE,
        null=True,
        blank=True,
        related_name="video_relations",
    )

    assigned_by = models.CharField(max_length=20, default="admin")

    created_at = models.DateTimeField(auto_now_add=True)
    updated_at = models.DateTimeField(auto_now=True)

    class Meta:
        constraints = [
            # 大ジャンル行の重複禁止
            models.UniqueConstraint(
                fields=["video", "major_genre"],
                condition=Q(medium_genre__isnull=True),
                name="uniq_videogenre_major_row"
            ),
            # 中ジャンル行の重複禁止
            models.UniqueConstraint(
                fields=["video", "medium_genre"],
                condition=Q(medium_genre__isnull=False),
                name="uniq_videogenre_medium_row"
            ),
        ]
        indexes = [
            models.Index(fields=["major_genre", "video"]),
            models.Index(fields=["medium_genre", "video"]),
            models.Index(fields=["video"]),
        ]

    def save(self, *args, **kwargs):
        # mediumがあるなら major を揃える（入力事故防止）
        if self.medium_genre_id:
            self.major_genre_id = self.medium_genre.major_genre_id
        super().save(*args, **kwargs)

    def __str__(self):
        return f"{self.video_id} - {self.major_genre_id} - {self.medium_genre_id}"


# =========================
# Votes: Add / Delete (anonymous count-based)
# =========================

THRESHOLD_VIDEO_GENRE_VOTES = 10


class VoteVideoGenreAdd(models.Model):
    """
    ジャンル追加提案（匿名・count集計）
    - medium=NULL の大ジャンル提案も許可（ただし is_must_medium=true は弾く）
    """
    video = models.ForeignKey(
        Work,
        on_delete=models.CASCADE,
        related_name="genre_add_vote_relations"
    )
    major_genre = models.ForeignKey(
        MajorGenre,
        on_delete=models.CASCADE,
        related_name="video_add_vote_relations"
    )
    medium_genre = models.ForeignKey(
        MediumGenre,
        on_delete=models.CASCADE,
        null=True,
        blank=True,
        related_name="video_add_vote_relations"
    )

    count = models.IntegerField(default=0)
    complete_flg = models.BooleanField(default=False)
    completed_at = models.DateTimeField(null=True, blank=True)

    created_at = models.DateTimeField(auto_now_add=True)
    updated_at = models.DateTimeField(auto_now=True)

    class Meta:
        constraints = [
            models.UniqueConstraint(
                fields=["video", "major_genre"],
                condition=Q(medium_genre__isnull=True),
                name="uniq_addvote_video_major_when_medium_null",
            ),
            models.UniqueConstraint(
                fields=["video", "medium_genre"],
                condition=Q(medium_genre__isnull=False),
                name="uniq_addvote_video_medium_when_medium_not_null",
            ),
        ]
        indexes = [
            models.Index(fields=["complete_flg", "count"]),
            models.Index(fields=["video"]),
            models.Index(fields=["major_genre"]),
            models.Index(fields=["medium_genre"]),
        ]

    def save(self, *args, **kwargs):
        if self.medium_genre_id:
            self.major_genre_id = self.medium_genre.major_genre_id
        super().save(*args, **kwargs)


