from django.db import models
from django.db.models import Q
from django.utils import timezone


# =========================
# Master: Office / Actress
# =========================

class Office(models.Model):
    name = models.CharField(max_length=255, unique=True)
    is_active = models.BooleanField(default=True)
    created_at = models.DateTimeField(auto_now_add=True)
    updated_at = models.DateTimeField(auto_now=True)

    def __str__(self):
        return self.name


class Actress(models.Model):
    name = models.CharField(max_length=255)
    other_name = models.CharField(max_length=255, blank=True, null=True)

    image_path = models.CharField(max_length=500, blank=True, null=True)
    explanation = models.TextField(blank=True, null=True)

    office = models.ForeignKey(
        Office,
        on_delete=models.SET_NULL,
        blank=True,
        null=True,
        related_name="actresses"
    )

    birth = models.DateField(blank=True, null=True)

    # 初期は文字列。将来検索したくなったら bust/waist/hip/cup 分割を推奨
    body_size = models.CharField(max_length=100, blank=True, null=True)

    debut_year = models.SmallIntegerField(blank=True, null=True)

    is_active = models.BooleanField(default=True)

    created_at = models.DateTimeField(auto_now_add=True)
    updated_at = models.DateTimeField(auto_now=True)

    class Meta:
        indexes = [
            models.Index(fields=["name"]),
            models.Index(fields=["is_active"]),
            models.Index(fields=["debut_year"]),
        ]

    def __str__(self):
        return self.name


# =========================
# Master: Maker / Label / Series
# =========================

class Maker(models.Model):
    name = models.CharField(max_length=255, unique=True)
    alias = models.CharField(max_length=255, blank=True, null=True)

    is_active = models.BooleanField(default=True)

    created_at = models.DateTimeField(auto_now_add=True)
    updated_at = models.DateTimeField(auto_now=True)

    def __str__(self):
        return self.name


class Label(models.Model):
    """
    事業構造上は Maker 配下が自然。
    必須にしたいなら maker を null=False に変更してください。
    """
    maker = models.ForeignKey(
        Maker,
        on_delete=models.CASCADE,
        related_name="labels"
    )

    name = models.CharField(max_length=255)
    alias = models.CharField(max_length=255, blank=True, null=True)

    is_active = models.BooleanField(default=True)

    created_at = models.DateTimeField(auto_now_add=True)
    updated_at = models.DateTimeField(auto_now=True)

    class Meta:
        constraints = [
            models.UniqueConstraint(
                fields=["maker", "name"],
                name="uniq_label_manufacturer_name"
            )
        ]
        indexes = [
            models.Index(fields=["maker", "name"]),
            models.Index(fields=["is_active"]),
        ]

    def __str__(self):
        return self.name


class Series(models.Model):
    # シリーズはレーベル不明もあり得るので NULL 可でスタート（必要なら NOT NULL に）
    label = models.ForeignKey(
        Label,
        on_delete=models.SET_NULL,
        blank=True,
        null=True,
        related_name="series"
    )

    name = models.CharField(max_length=255)
    alias = models.CharField(max_length=255, blank=True, null=True)

    is_active = models.BooleanField(default=True)

    created_at = models.DateTimeField(auto_now_add=True)
    updated_at = models.DateTimeField(auto_now=True)

    class Meta:
        indexes = [
            models.Index(fields=["name"]),
            models.Index(fields=["is_active"]),
        ]

    def __str__(self):
        return self.name


